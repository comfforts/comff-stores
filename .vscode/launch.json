    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}"
        },
        {
            "name": "Launch Store Server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "cmd/servers/stores/server.go",
            "envFile": "${workspaceFolder}/env/stores.env",
            "args": ["-v"],
        },
        {
            "name": "Launch client test",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "cmd/clients/stores/client.go",
            "args": ["-v"],
        },
    ]
}